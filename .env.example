# Backend
PORT=3001

# Pick the database backend. Allowed: sqlite (default, zero-setup) or postgresql.
# After flipping this, re-run `pnpm --filter backend prisma:generate` and
# `pnpm --filter backend migrate` so the Prisma client + migrations match.
DB_PROVIDER=sqlite

# DATABASE_URL must match DB_PROVIDER.
#   sqlite      : file:../../database/roots.db   (path is relative to backend/prisma/schema.prisma)
#   postgresql  : postgresql://USER:PASS@HOST:5432/DBNAME?schema=public
DATABASE_URL="file:../../database/roots.db"

JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="7d"
# Optional cookie scope. Leave unset to bind the auth cookie to the exact
# request Host. Set when frontend and api live on different subdomains of the
# same registrable domain (e.g. "example.com" to share between
# example.com / api.example.com).
# COOKIE_DOMAIN="example.com"
NODE_ENV="development"
# Hops of trusted reverse proxies in front of this process. 0 (default) means
# we ignore X-Forwarded-For entirely — required when the process is directly
# exposed to the internet, otherwise login rate-limiting can be bypassed by
# spoofed XFF headers. Set to 1 when behind nginx/cloudfront/etc.
TRUST_PROXY=0
UPLOAD_DIR="../uploads"
BACKUP_DIR="../backups"
CORS_ORIGIN="http://localhost:5173"

# Frontend (Vite). Leave empty so API calls go through Vite's proxy in dev and stay
# same-origin in prod. Set to a full URL only when the API lives on a separate host.
VITE_API_URL=""
