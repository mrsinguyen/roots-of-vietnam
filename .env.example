# Backend
PORT=3001
# SQLite path resolves relative to schema.prisma at backend/prisma/schema.prisma
DATABASE_URL="file:../../database/roots.db"
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="7d"
COOKIE_DOMAIN="localhost"
NODE_ENV="development"
UPLOAD_DIR="../uploads"
BACKUP_DIR="../backups"
CORS_ORIGIN="http://localhost:5173"

# Frontend (Vite). Leave empty so API calls go through Vite's proxy in dev and stay
# same-origin in prod. Set to a full URL only when the API lives on a separate host.
VITE_API_URL=""
