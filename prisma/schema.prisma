// Prisma schema for the Cloudflare D1 deployment track.
// D1 is SQLite under the hood, so this uses `provider = "sqlite"` plus the
// `driverAdapters` preview feature and the `@prisma/adapter-d1` runtime
// adapter (the D1 binding is only reachable from inside a Worker request).
//
// Model bodies are kept identical to backend/prisma/schema.prisma and
// backend/prisma/postgres/schema.prisma — `pnpm check:schemas` fails loud on
// drift across all three (it ignores the generator + datasource blocks).
//
// The `url` is unused at runtime (the adapter supplies the D1 connection) but
// Prisma 6.x still requires it for `prisma validate` / `generate` / `migrate
// diff`. A literal placeholder is used (not env("DATABASE_URL")) so generate
// works in build environments that have no .env, e.g. Cloudflare Pages CI.

generator client {
  provider = "prisma-client-js"
  output   = "./generated"
}

datasource db {
  provider = "sqlite"
  url      = "file:./d1-placeholder.db"
}

model Person {
  id             String  @id @default(cuid())
  fullName       String
  nameNormalized String  @default("")
  honorific      String?
  gender         String
  birthYear      Int?
  birthMonth     Int?
  birthDay       Int?
  deathYear      Int?
  deathMonth     Int?
  deathDay       Int?
  birthDateLunar String?
  deathDateLunar String?
  biography      String?
  occupation     String?
  burialPlace    String?
  notes          String?
  generation     Int     @default(1)

  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id])

  fatherId         String?
  father           Person?  @relation("Father", fields: [fatherId], references: [id])
  childrenAsFather Person[] @relation("Father")

  motherId         String?
  mother           Person?  @relation("Mother", fields: [motherId], references: [id])
  childrenAsMother Person[] @relation("Mother")

  marriagesAsHusband Marriage[] @relation("Husband")
  marriagesAsWife    Marriage[] @relation("Wife")

  media Media[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([fullName])
  @@index([nameNormalized])
  @@index([generation])
  @@index([branchId])
  @@index([fatherId])
  @@index([motherId])
  @@index([birthYear])
}

model Marriage {
  id           String    @id @default(cuid())
  husbandId    String
  husband      Person    @relation("Husband", fields: [husbandId], references: [id])
  wifeId       String
  wife         Person    @relation("Wife", fields: [wifeId], references: [id])
  marriageDate DateTime?
  createdAt    DateTime  @default(now())

  @@unique([husbandId, wifeId])
  @@index([husbandId])
  @@index([wifeId])
}

model Branch {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  persons     Person[]
  createdAt   DateTime @default(now())
}

model Media {
  id        String   @id @default(cuid())
  personId  String
  person    Person   @relation(fields: [personId], references: [id], onDelete: Cascade)
  filePath  String
  type      String
  caption   String?
  createdAt DateTime @default(now())

  @@index([personId])
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  role         String   @default("viewer")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  auditLogs AuditLog[]
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action     String
  targetType String?
  targetId   String?
  diff       String?
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([userId])
  @@index([action])
}
