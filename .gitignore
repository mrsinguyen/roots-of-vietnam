database/*.db
database/*.db-journal
uploads/*
!uploads/.gitkeep
backups/*
!backups/.gitkeep
tmp/

# Environment (.env.example IS tracked as a template)
.env
.env.*
!.env.example

# Test artifacts
coverage/
test-results/
playwright-report/
.playwright-mcp/
*.local.png

# Editor / OS
.DS_Store
.idea/
.vscode/
*.swp
*.swo

# Logs
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# Misc
.claude/

# wrangler local dev secrets
.dev.vars

# Generated seed SQL (from prisma/seed.mjs)
prisma/seed.sql
