{
  "name": "roots-of-vietnam",
  "version": "0.2.0",
  "private": true,
  "description": "Gia Phả Việt — Vietnamese-first PWA genealogy system for any Vietnamese family",
  "scripts": {
    "dev": "concurrently -n backend,frontend -c blue,green \"pnpm --filter backend dev\" \"pnpm --filter frontend dev\"",
    "build": "pnpm --filter backend build && pnpm --filter frontend build",
    "seed": "pnpm --filter backend seed",
    "migrate": "pnpm --filter backend migrate",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "check:schemas": "node backend/scripts/check-schemas-in-sync.mjs",
    "test": "pnpm check:schemas && vitest run",
    "test:watch": "vitest",
    "test:coverage": "pnpm check:schemas && vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:all": "pnpm test:coverage && pnpm test:e2e"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@prisma/client": "^6.19.3",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^1.4.13",
    "@types/node": "^24.0.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@types/supertest": "^6.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^2.1.8",
    "bcryptjs": "^2.4.3",
    "concurrently": "^9.1.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "express": "^4.22.2",
    "fake-indexeddb": "^6.2.5",
    "idb-keyval": "^6.2.2",
    "jsdom": "^25.0.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "1.4.5-lts.2",
    "prettier": "^3.4.2",
    "prisma": "6.19.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.3",
    "supertest": "^7.0.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "zod": "^3.25.76"
  },
  "packageManager": "pnpm@11.0.8",
  "engines": {
    "node": ">=24"
  }
}
