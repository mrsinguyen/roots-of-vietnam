{
  "name": "roots-of-vietnam",
  "version": "1.0.0",
  "private": true,
  "description": "Gia Phả Việt — Vietnamese-first PWA genealogy system on Cloudflare (D1 + Pages)",
  "scripts": {
    "dev": "wrangler pages dev",
    "dev:web": "pnpm --filter frontend dev",
    "build": "pnpm cf:build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck && pnpm typecheck:worker",
    "typecheck:worker": "tsc --noEmit -p worker/tsconfig.json",
    "prisma:generate": "prisma generate --schema=prisma/schema.prisma",
    "prisma:migrate:diff": "prisma migrate diff --from-empty --to-schema-datamodel prisma/schema.prisma --script > prisma/migrations/0001_init.sql",
    "migrate:local": "wrangler d1 migrations apply roots-of-vietnam --local",
    "migrate:remote": "wrangler d1 migrations apply roots-of-vietnam --remote",
    "seed:local": "node prisma/seed.mjs > prisma/seed.sql && wrangler d1 execute roots-of-vietnam --local --file=prisma/seed.sql",
    "seed:remote": "node prisma/seed.mjs > prisma/seed.sql && wrangler d1 execute roots-of-vietnam --remote --file=prisma/seed.sql",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:workers": "pnpm prisma:generate && vitest run --config vitest.workers.config.ts",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:all": "pnpm test:coverage && pnpm test:workers && pnpm test:e2e",
    "cf:build": "pnpm prisma:generate && pnpm --filter frontend build",
    "cf:deploy": "pnpm cf:build && wrangler pages deploy"
  },
  "dependencies": {
    "@prisma/adapter-d1": "6.19.3",
    "@prisma/client": "6.19.3",
    "bcryptjs": "^2.4.3",
    "hono": "^4.12.23",
    "jose": "^5.10.0",
    "jszip": "^3.10.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260526.1",
    "@playwright/test": "^1.49.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^24.0.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^2.1.8",
    "fake-indexeddb": "^6.2.5",
    "idb-keyval": "^6.2.2",
    "jsdom": "^25.0.1",
    "prettier": "^3.4.2",
    "prisma": "6.19.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.3",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "wrangler": "^4.95.0"
  },
  "packageManager": "pnpm@11.0.8",
  "engines": {
    "node": ">=24"
  }
}
