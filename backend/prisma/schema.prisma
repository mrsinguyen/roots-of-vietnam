// Prisma schema for Roots of Vietnam.
// SQLite stores enums as TEXT — Prisma maps enum values from the typed client side.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Person {
  id             String  @id @default(cuid())
  fullName       String
  // Lowercased, diacritic-stripped fullName so search is diacritic-insensitive.
  // Maintained by the application on every write.
  nameNormalized String  @default("")
  // Vietnamese honorific shown before the name (Cụ, Ông, Bà, Cố, …).
  honorific      String?
  // Gender stored as text: "Nam" | "Nu" | "Khac"
  gender         String
  // Partial-date support: year required for a known date, month and day optional.
  birthYear      Int?
  birthMonth     Int?
  birthDay       Int?
  deathYear      Int?
  deathMonth     Int?
  deathDay       Int?
  // Free-text âm lịch (lunar) dates shown alongside the solar values.
  birthDateLunar String?
  deathDateLunar String?
  biography      String?
  occupation     String?
  burialPlace    String?
  notes          String?
  generation     Int     @default(1)

  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id])

  fatherId         String?
  father           Person?  @relation("Father", fields: [fatherId], references: [id])
  childrenAsFather Person[] @relation("Father")

  motherId         String?
  mother           Person?  @relation("Mother", fields: [motherId], references: [id])
  childrenAsMother Person[] @relation("Mother")

  marriagesAsHusband Marriage[] @relation("Husband")
  marriagesAsWife    Marriage[] @relation("Wife")

  media Media[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([fullName])
  @@index([nameNormalized])
  @@index([generation])
  @@index([branchId])
  @@index([fatherId])
  @@index([motherId])
  @@index([birthYear])
}

model Marriage {
  id           String    @id @default(cuid())
  husbandId    String
  husband      Person    @relation("Husband", fields: [husbandId], references: [id])
  wifeId       String
  wife         Person    @relation("Wife", fields: [wifeId], references: [id])
  marriageDate DateTime?
  createdAt    DateTime  @default(now())

  @@unique([husbandId, wifeId])
  @@index([husbandId])
  @@index([wifeId])
}

model Branch {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  persons     Person[]
  createdAt   DateTime @default(now())
}

model Media {
  id        String   @id @default(cuid())
  personId  String
  person    Person   @relation(fields: [personId], references: [id], onDelete: Cascade)
  filePath  String
  // type stored as text: "image" | "pdf" | "audio" | "doc"
  type      String
  caption   String?
  createdAt DateTime @default(now())

  @@index([personId])
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  // role stored as text: "admin" | "editor" | "viewer"
  role         String   @default("viewer")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  auditLogs AuditLog[]
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action     String
  targetType String?
  targetId   String?
  // JSON blob: { before?, after? } for mutations, or { meta } for non-data actions.
  diff       String?
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([userId])
  @@index([action])
}
