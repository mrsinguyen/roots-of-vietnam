{
  "name": "backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=../.env src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node --env-file=../.env dist/server.js",
    "seed": "tsx --env-file=../.env prisma/seed.ts",
    "migrate": "node scripts/run-prisma.mjs migrate dev",
    "migrate:deploy": "node scripts/run-prisma.mjs migrate deploy",
    "prisma:generate": "node scripts/run-prisma.mjs generate",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/client": "^6.0.1",
    "@roots/shared": "workspace:*",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "zod": "^3.24.1"
  },
  "engines": {
    "node": ">=24"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^1.4.12",
    "@types/node": "^24.0.0",
    "prisma": "6.19.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
